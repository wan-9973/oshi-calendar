# https://webservice.rakuten.co.jp/app/create で取得（コード直書き禁止）
RAKUTEN_APP_ID=
# https://webservice.rakuten.co.jp/app/list で確認（2026年より全API必須）
RAKUTEN_ACCESS_KEY=
# https://webservice.rakuten.co.jp/app/account_affiliate_id で確認
RAKUTEN_AFFILIATE_ID=
# サイト名・運営者表記（規約11条1項）
SITE_NAME=推しカレンダー
OPERATOR_NAME=

# --- Vercel + Supabase 運用時のみ ---
# SupabaseのTransaction Pooler接続文字列（Settings > Database > Connection string）
DATABASE_URL=
# デプロイ後の公開URL（例: https://oshi-calendar.vercel.app）
SITE_URL=
# Cron保護用のランダム文字列（Vercelの環境変数にも同名で設定）
CRON_SECRET=
# 任意: ヘルス判定・履歴保持（未設定時は26時間/10分/90日）
CRON_HEALTH_MAX_AGE_HOURS=26
CRON_JOB_STUCK_MINUTES=10
JOB_RUN_TTL_DAYS=90

# --- 関連度フィルタ（幅が広すぎる関連商品の抑制） ---
# 中古・楽譜/スコア・カラオケ等の周辺商品を除外（既定=有効）。誤除去時は 0 で無効化。
OSHI_FILTER_NOISE=1
# 楽天APIのNGKeywordに渡す除外語（キーワード検索系のみ）。空で送信しない。
OSHI_NG_SEARCH_KEYWORDS=中古 レンタル 楽譜 カラオケ
# 説明文だけに名前が出る商品も表示したい場合は 1（既定=0で非表示）。
OSHI_SHOW_CAPTION_ONLY=0
