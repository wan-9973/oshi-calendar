# 任意: Vercel Hobbyのcron（1日1回×2本）では巡回容量が足りなくなった場合に、
# GitHub Actionsから10分おきに巡回エンドポイントを叩いて増枠する。
# 有効化: このファイルを crawl.yml にリネームし、リポジトリのSecretsに
#   APP_URL（例: https://oshi-calendar.vercel.app）と CRON_SECRET を登録。
name: crawl
on:
  schedule:
    - cron: "*/10 18-19 * * *"   # UTC 18-19時台（JST 3-4時台）に10分間隔
  workflow_dispatch: {}
jobs:
  crawl:
    runs-on: ubuntu-latest
    steps:
      - run: |
          curl -sS --fail-with-body -H "Authorization: Bearer ${{ secrets.CRON_SECRET }}" \
            "${{ secrets.APP_URL }}/api/cron/crawl"
